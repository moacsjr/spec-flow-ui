# Configuração opcional para buscar um Epic real do GitHub.
# Sem estas variáveis, o app renderiza o fixture local (src/data/fixture.ts).
#
# O token precisa de leitura de issues do repositório (escopo `repo` / read-only)
# e a API de sub-issues habilitada na conta.

VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
VITE_GITHUB_REPO=owner/repo
VITE_GITHUB_EPIC_ISSUE=204
# Opcional — sobrescreve o time exibido (senão vem da label `team:*` ou do milestone).
VITE_GITHUB_TEAM=Squad Checkout
