# Porta do servidor Express em DEV LOCAL (frontend Vite roda em 5173 e faz
# proxy de /api → 3001). Em produção o app roda como Lambda (lambda.ts).
PORT=3001

# --- Multi-tenant / DynamoDB ---
# Nome da tabela single-table (criada pelo CDK em infra/).
TABLE_NAME=spec-wave
# Dev local: aponte para um dynamodb-local (docker run -p 8000:8000 amazon/dynamodb-local).
# DYNAMODB_ENDPOINT=http://localhost:8000
# Dev local SEM Cognito: tenant fixo injetado pelo middleware de auth.
# Ignorado quando NODE_ENV=production.
DEV_TENANT_ID=dev-tenant

# --- GitHub App (credencial por tenant; NÃO existe mais GITHUB_TOKEN global) ---
# Em produção a private key e o webhook secret vêm do Secrets Manager (ARNs
# injetados pelo CDK). Em dev local, cole os valores direto:
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=meu-spec-wave-app
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
# GITHUB_WEBHOOK_SECRET=troque-me
# Produção (setados pela infra, não manualmente):
# GITHUB_APP_PRIVATE_KEY_SECRET_ARN=arn:aws:secretsmanager:...
# GITHUB_WEBHOOK_SECRET_ARN=arn:aws:secretsmanager:...
# Opcional — fallback do time exibido (senão vem da label `team:*` ou do milestone).
GITHUB_TEAM=Squad Checkout

# --- LLM via OpenRouter (refino interativo de spec.md/plan.md pela UI) ---
# Produção: OPENROUTER_SECRET_ARN (Secrets Manager). Dev local: chave direta.
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
# OPENROUTER_SECRET_ARN=arn:aws:secretsmanager:...
# Opcional — modelo usado (default deepseek/deepseek-chat). Evite modelos
# reasoning no refine síncrono: estouram o teto de 29 s do API Gateway.
OPENROUTER_MODEL=deepseek/deepseek-chat
# Opcional — teto de tokens de saída do refino (default 8000).
OPENROUTER_MAX_TOKENS=8000

# --- Billing via Stripe (fase 3) ---
# Produção: STRIPE_SECRET_ARN / STRIPE_WEBHOOK_SECRET_ARN (Secrets Manager).
# Dev local: valores diretos (use as chaves de teste sk_test_/whsec_).
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price recorrente do plano pro (Stripe Dashboard → Products):
# STRIPE_PRICE_PRO=price_xxx

# URL pública do app (redirects do Stripe Checkout). Produção: CloudFront.
# APP_URL=https://xxxx.cloudfront.net/

# KMS para cifrar a chave OpenRouter própria de cada tenant (produção: setado
# pela infra). Sem valor, o cadastro de chave própria responde 503.
# TENANT_KMS_KEY_ID=xxxx
