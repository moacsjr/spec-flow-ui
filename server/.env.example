# Porta do servidor Express (frontend Vite roda em 5173 em dev).
PORT=3001

# Origem permitida no CORS (URL do frontend em dev). Em produção (processo
# único) o frontend é servido pelo próprio Express, então o CORS é dispensável.
CORS_ORIGIN=http://localhost:5173

# Caminho do arquivo SQLite (relativo à raiz do pacote server/).
DATABASE_FILE=./data/database.db

# --- Integração com o GitHub (vive SÓ no backend; o token nunca vai ao browser) ---
# O token precisa de leitura de issues dos repositórios e da API de sub-issues
# habilitada na conta. Para EDITAR título/descrição pela UI, o token também
# precisa de ESCRITA em issues (escopo clássico `repo`, ou fine-grained com
# Issues: Read and write). O repositório-alvo de cada tela vem da url do
# repositório cadastrado (SQLite), não do env.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Opcional — fallback do time exibido (senão vem da label `team:*` ou do milestone).
GITHUB_TEAM=Squad Checkout

# --- LLM via OpenRouter (refino interativo de spec.md/plan.md pela UI) ---
# A chave vive SÓ no backend. Sem ela, os endpoints de refino retornam 503.
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
# Opcional — modelo usado (default deepseek/deepseek-v4-pro).
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
# Opcional — teto de tokens de saída do refino (default 8000). Evita truncar o
# documento; aumente se gerar specs/plans muito longos.
OPENROUTER_MAX_TOKENS=8000

# Em produção, defina para servir o build do frontend (client/dist) pelo Express:
# SERVE_STATIC=true
